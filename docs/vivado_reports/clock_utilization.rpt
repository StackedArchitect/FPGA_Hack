# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y16 [get_cells clk_100_BUFG_inst]

# Location of IO Primitives which is load of clock spine

# Location of clock ports
set_property LOC IOB_X1Y125 [get_ports sys_clk_n]
set_property LOC IOB_X1Y126 [get_ports sys_clk_p]

# Clock net "clk_100_BUFG" driven by instance "clk_100_BUFG_inst" located at site "BUFGCTRL_X0Y16"
#startgroup
create_pblock {CLKAG_clk_100_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_clk_100_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="clk_100_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_clk_100_BUFG}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1 CLOCKREGION_X1Y2:CLOCKREGION_X1Y2}
#endgroup
