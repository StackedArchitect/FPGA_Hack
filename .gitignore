# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Dataset files (too large for git — download separately)
software/data/*.pkl
software/data/*.hdf5
software/data/*.h5
software/data/*.tar.bz2

# Trained models and results (regenerated by running main.py)
software/results/*.npz
software/results/*.png

# FPGA export hex/coe files (regenerated by --export flag)
hardware/tb/test_vectors/*.hex
hardware/tb/test_vectors/*.coe
hardware/tb/test_vectors/*.vh

# Vivado generated files
hardware/vivado/hdc_amc/
*.jou
*.log
*.str
*.bit
*.bin
*.ltx

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
*.swp
*.swo
